<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Shop</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

  <!-- Header -->
  <div class="flex justify-between items-center px-10 py-4 border-b bg-white">
    <h1 class="text-lg font-medium">Shop.</h1>

    <div class="flex gap-6 text-sm text-gray-600">
      <a href="#">Home</a>
      <a href="#">Products</a>
      <a href="#">Cart</a>
      <a href="#">My account</a>
    </div>
  </div>

  <!-- Main -->
  <div class="flex px-10 py-6">

    <!-- Sidebar -->
<div class="w-60 bg-white p-5 rounded-lg shadow-sm h-fit sticky top-6">

  <!-- Sort -->
  <div class="mb-6">
    <p class="text-xs text-gray-400 uppercase mb-2 tracking-wide">Sort by</p>

    <a href="#" class="block px-3 py-2 rounded bg-gray-100 text-gray-800 font-medium hover:bg-gray-200 transition">
      Popular
    </a>
  </div>

  <!-- Collection -->
  <div class="mb-6">
    <p class="text-xs text-gray-400 uppercase mb-2 tracking-wide">Collection</p>

    <a href="/users/shop" class="block px-3 py-2 rounded hover:bg-gray-100 transition">
      All Products
    </a>

    <a href="#" class="block px-3 py-2 rounded hover:bg-gray-100 transition">
      Discounted Products
    </a>
  </div>

  <!-- Filters -->
  <div>
    <p class="text-xs text-gray-400 uppercase mb-2 tracking-wide">Filter by</p>

    <a href="#" class="block px-3 py-2 rounded hover:bg-gray-100 transition flex justify-between items-center">
      Availability
      <span class="text-xs text-gray-400">›</span>
    </a>

    <a href="#" class="block px-3 py-2 rounded hover:bg-gray-100 transition flex justify-between items-center">
      Discount
      <span class="text-xs text-gray-400">›</span>
    </a>
  </div>

</div>

    <!-- Products Grid -->
    <div class="flex-1 ml-10">

      <div class="grid grid-cols-4 gap-8">

        <!-- CARD -->
      <% if(products && products.length>0) { %>
        <% products.forEach((product)=>{ %>
          <div class="bg-[#e7cfc8] p-4">
            <img src="<%= product.image %>" class="w-full h-44 object-contain">

            <div class="mt-3 flex justify-between items-center">
              <div>
                <p class="text-sm"><%= product.name %></p>
                <p class="text-xs text-gray-700">₹ <%= product.price%></p>
              </div>

              <div class="w-7 h-7 bg-white rounded-full flex items-center justify-center text-sm">
                <a href = "#"> + </a>
              </div>
            </div>
          </div>
        <% })%>
      <% } %>

      </div>

    </div>

  </div>

</body>
</html>