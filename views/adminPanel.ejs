<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Admin Panel</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

  <!-- Header -->
  <div class="flex justify-between items-center px-10 py-4 border-b bg-white">
    <h1 class="text-lg font-semibold">Admin Panel.</h1>

    <div class="flex gap-6 text-sm text-gray-600">
      <a href="#">Home</a>
      <a href="#">Products</a>
      <a href="#">Cart</a>
      <a href="#">My account</a>
    </div>
  </div>

  <!-- Main -->
  <div class="flex px-10 py-6">

    <!-- Sidebar -->
    <div class="w-56">

      <div class="bg-white p-5 rounded-lg shadow-sm">

        <a href="/owners/adminPanel" class="block mb-3 text-gray-800 font-medium hover:text-black">
          All Products
        </a>

        <a href="/products/create" class="block mb-3 text-gray-600 hover:text-black">
          Create New Product
        </a>

        <a href="#" class="block text-red-500 text-sm hover:underline mt-4">
          Delete All
        </a>

      </div>

    </div>

    <!-- Products Grid -->
    <div class="flex-1 ml-10">

      <div class="grid grid-cols-4 gap-8">
        <% if(products && products.length){ %>
        <% products.forEach((product)=>{ %>
        <% const imageSrc = typeof product.image === 'string' ? product.image : '/images/defaultProductImg.jpeg'; %>
        <% const productName = typeof product.name === 'string' ? product.name : ''; %>
        <% const productPrice = typeof product.price === 'number' || typeof product.price === 'string' ? product.price : ''; %>
        <!-- CARD 1 -->
          <div style="background-color: <%= product.bgcolour || '#e5e5e5' %>" class="p-4 rounded">
          <img 
            src="<%= imageSrc %>"
            class="w-full h-44 object-contain"
          >
          <div class="mt-3 flex justify-between items-center">
            <div>
              <p class="text-sm"><%= productName %></p>
              <p class="text-xs text-gray-700">₹ <%= productPrice %></p>
            </div>
            <div class="flex gap-2">
              <a href="#" class="text-xs text-blue-500 hover:underline">Edit</a>
              <a href="#" class="text-xs text-red-500 hover:underline">Delete</a>
            </div>
          </div>
        </div>
        <% }) }%>

      </div>

    </div>

  </div>

</body>
</html>