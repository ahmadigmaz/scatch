<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Create Product</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

  <!-- Header -->
  <div class="flex justify-between items-center px-10 py-4 border-b bg-white">
    <h1 class="text-lg font-semibold">Admin Panel.</h1>

    <div class="flex gap-6 text-sm text-gray-600">
      <a href="#">Home</a>
      <a href="#">Products</a>
      <a href="#">Cart</a>
      <a href="#">My account</a>
    </div>
  </div>

  <!-- Layout -->
  <div class="flex px-10 py-6">

    <!-- Sidebar -->
    <div class="w-56">
      <div class="bg-white p-5 rounded-lg shadow-sm">
        <a href="/owners/adminPanel" class="block mb-3 text-gray-600 hover:text-black">
          All Products
        </a>

        <a href="/products/create" class="block font-medium text-black">
          Create New Product
        </a>
      </div>
    </div>

    <!-- Content -->
    <div class="flex-1 ml-10">

      <h2 class="text-lg font-medium mb-6">Create New Product</h2>

      <!-- FORM -->
      <form 
        action="/products/create" 
        method="POST" 
        enctype="multipart/form-data"
        class="bg-white p-8 rounded-lg shadow-sm w-[650px]"
      >

        <!-- Product Details -->
        <h3 class="text-md font-medium mb-4">Product Details</h3>

        <!-- Image -->
        <div class="mb-4">
          <label class="text-sm text-gray-600 block mb-2">Product Image</label>
          <input 
            type="file" 
            name="image"
            class="text-sm"
          />
        </div>

        <!-- Name -->
        <input 
          type="text" 
          name="name"
          placeholder="Product Name"
          required
          class="w-full px-4 py-2 mb-4 bg-gray-100 rounded outline-none focus:ring-2 focus:ring-blue-400"
        />

        <!-- Price + Discount -->
        <div class="flex gap-4 mb-6">
          <input 
            type="number" 
            name="price"
            placeholder="Product Price"
            required
            class="w-1/2 px-4 py-2 bg-gray-100 rounded outline-none focus:ring-2 focus:ring-blue-400"
          />

          <input 
            type="number" 
            name="discount"
            placeholder="Discount %"
            class="w-1/2 px-4 py-2 bg-gray-100 rounded outline-none focus:ring-2 focus:ring-blue-400"
          />
        </div>

        <!-- Panel Details -->
        <h3 class="text-md font-medium mb-4">Panel Details</h3>

        <div class="grid grid-cols-3 gap-4 mb-6">

          <!-- Background Color -->
          <div>
            <label class="text-xs text-gray-500">Background</label>
            <input 
              type="color" 
              name="bgcolour"
              value="#e5e5e5"
              class="w-full h-10 p-1 bg-gray-100 rounded cursor-pointer"
            />
          </div>

          <!-- Panel Color -->
          <div>
            <label class="text-xs text-gray-500">Panel</label>
            <input 
              type="color" 
              name="panelcolour"
              value="#ffffff"
              class="w-full h-10 p-1 bg-gray-100 rounded cursor-pointer"
            />
          </div>

          <!-- Text Color -->
          <div>
            <label class="text-xs text-gray-500">Text</label>
            <input 
              type="color" 
              name="textcolour"
              value="#000000"
              class="w-full h-10 p-1 bg-gray-100 rounded cursor-pointer"
            />
          </div>

        </div>

        <!-- Submit -->
        <button class="bg-blue-500 text-white px-6 py-2 rounded-full hover:bg-blue-600 transition">
          Create Product
        </button>

      </form>

    </div>

  </div>

</body>
</html>